# Copy this file to settings.toml on the CIRCUITPY drive and fill in your values.
# Floats are not supported directly in settings.toml, so latitude/longitude
# should stay quoted as strings.

CIRCUITPY_WIFI_SSID = "your_wifi_name"
CIRCUITPY_WIFI_PASSWORD = "your_wifi_password"

# Optional, but strongly recommended for better OpenSky limits.
OPENSKY_CLIENT_ID = "your_opensky_client_id"
OPENSKY_CLIENT_SECRET = "your_opensky_client_secret"

PLANEPORTAL_HOME_LATITUDE = "47.6062"
PLANEPORTAL_HOME_LONGITUDE = "-122.3321"

PLANEPORTAL_RADIUS_MILES = "3"
PLANEPORTAL_REFRESH_SECONDS = 120
PLANEPORTAL_RECENT_WINDOW_MINUTES = 10
PLANEPORTAL_ADSB_CACHE_SECONDS = 1800
PLANEPORTAL_ENRICHMENT_LIMIT = 4
PLANEPORTAL_DEBUG = "0"